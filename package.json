{
  "name": "frontlens",
  "version": "0.1.0",
  "description": "AI-oriented frontend QA analyzer powered by Playwright.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./resultNormalizer": {
      "types": "./dist/resultNormalizer.d.ts",
      "import": "./dist/resultNormalizer.js"
    }
  },
  "bin": {
    "frontlens": "./dist/cli.js"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsx src/cli.ts",
    "qa": "tsx src/cli.ts qa",
    "mcp": "node dist/cli.js mcp",
    "check": "tsc -p tsconfig.json --noEmit",
    "test": "node --import tsx --test test/*.test.ts"
  },
  "dependencies": {
    "playwright": "^1.54.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsx": "^4.20.0",
    "typescript": "^5.8.0"
  },
  "engines": {
    "node": ">=20"
  }
}
